---
// Astro wrapper for the React desktop island.
// Gated by media query in the surrounding section so the island only
// hydrates on desktop viewports with a fine pointer.
//
// CSS STRATEGY: xp.scoped.css and desktop.css are imported here (Astro
// frontmatter), NOT inside Desktop.tsx. Astro emits one route-level CSS
// chunk; the hydrated React island finds the styles already in the
// document instead of duplicating ~250 KB of XP.css into the client JS
// chunk.
//
// xp.scoped.css is generated by `node scripts/scope-xpcss.mjs` from
// node_modules/xp.css/dist/XP.css. Re-run that script after upgrading
// xp.css. The scope is `.xp-scope`, applied on the root <div> in
// Desktop.tsx so the (heavy) XP global rules cannot bleed into the rest
// of the Portfolio.
import "./xp.scoped.css";
import "./desktop.css";
import Desktop from "./Desktop";
---

<!--
  client:media gates hydration to the same MQ as the CSS .desktop-only
  reveal and desktop.css scroll lock. On mobile/touch the React island
  never hydrates at all — save ~25 KB gz of JS execution on phones.
  Round-1 note: client:visible was abandoned because the zero-height
  parent (before the :has hack landed) broke IntersectionObserver.
  client:media sidesteps IO entirely.
-->
<Desktop client:media="(min-width: 1024px) and (pointer: fine)" />
