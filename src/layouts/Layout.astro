---
import '@fontsource/fraunces/400.css';
import '@fontsource/fraunces/500.css';
import '@fontsource/fraunces/600.css';
import '@fontsource/fraunces/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Alex Friedrichsen — data scientist, builder, and human who grows with friends, finds joy in hard problems, and builds things that help people." />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #f7f4ee;
    --ink: #1a1a1a;
    --ink-soft: #4a4a4a;
    --rule: #d8d3c7;
    /* Accent: burnt terracotta — warm, not Bootstrap blue */
    --accent: #b8552a;
    --accent-soft: #e8c7b3;
    --serif: 'Fraunces', Georgia, 'Times New Roman', serif;
    --sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--sans);
    font-size: 18px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent-soft); }
  a:hover { border-bottom-color: var(--accent); }

  img { max-width: 100%; display: block; height: auto; }

  section { padding: 8rem 2rem; }
  .wrap { max-width: 1080px; margin: 0 auto; }
  .wrap-narrow { max-width: 760px; margin: 0 auto; }

  /* ---------- Movement 1: cold open ---------- */
  #philosophy {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 2rem 4rem;
  }
  .triptych {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(2.2rem, 6.5vw, 5.5rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ink);
  }
  .triptych span {
    display: block;
    opacity: 0;
    transform: translateY(12px);
    animation: rise 1.1s cubic-bezier(.2,.7,.2,1) forwards;
  }
  .triptych span:nth-child(1) { animation-delay: 0.15s; }
  .triptych span:nth-child(2) { animation-delay: 0.55s; color: var(--ink-soft); }
  .triptych span:nth-child(3) { animation-delay: 0.95s; }
  .triptych .period { color: var(--accent); }
  @keyframes rise {
    to { opacity: 1; transform: translateY(0); }
  }
  /* JS-off fallback — all visible */
  .no-anim .triptych span { opacity: 1; transform: none; animation: none; }

  .byline {
    margin-top: 4rem;
    font-family: var(--sans);
    font-size: 1rem;
    color: var(--ink-soft);
    letter-spacing: 0.02em;
  }
  .byline strong { color: var(--ink); font-weight: 600; }
  .byline .sep { margin: 0 0.6rem; color: var(--rule); }

  /* ---------- Section headers ---------- */
  .section-label {
    font-family: var(--sans);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.8rem;
  }
  .section-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin: 0 0 3rem;
  }

  /* ---------- Movement 2: beats ---------- */
  .beat { margin-bottom: 7rem; }
  .beat:last-child { margin-bottom: 0; }
  .beat h3 {
    font-family: var(--serif);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 600;
    line-height: 1.15;
    margin: 0 0 0.4rem;
  }
  .beat .proves {
    font-family: var(--sans);
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 1.4rem;
    font-weight: 600;
  }
  .beat p { margin: 0 0 1.1rem; max-width: 62ch; color: var(--ink-soft); }
  .beat p strong { color: var(--ink); }
  .beat .gallery {
    margin-top: 2rem;
    display: grid;
    gap: 1.4rem;
  }
  .beat .gallery.two { grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); }
  .beat .gallery.three { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .beat .gallery.hero-arc { grid-template-columns: 1fr; gap: 1.4rem; }
  .beat .gallery.hero-arc .hero img { width: 100%; }
  .beat .gallery.hero-arc .supporting {
    display: grid;
    gap: 1.4rem;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  }
  .beat .gallery.hero-arc .supporting figure { margin: 0; }
  .beat figure { margin: 0; }
  .beat figure img {
    width: 100%;
    border: 1px solid var(--rule);
    background: #fff;
  }
  .beat figcaption {
    font-size: 0.82rem;
    color: var(--ink-soft);
    margin-top: 0.6rem;
    font-style: italic;
  }

  /* ---------- Movement 3: agent grid ---------- */
  #practice { background: #efeae0; }
  .agent-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.4rem;
    margin-top: 3rem;
  }

  /* ---------- Footer ---------- */
  footer {
    padding: 3rem 2rem 4rem;
    border-top: 1px solid var(--rule);
    font-size: 0.88rem;
    color: var(--ink-soft);
  }
  footer .wrap { display: flex; flex-wrap: wrap; gap: 1.4rem; justify-content: space-between; }

  @media (max-width: 680px) {
    section { padding: 5rem 1.4rem; }
    #philosophy { padding: 4rem 1.4rem 3rem; }
    .beat { margin-bottom: 5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .triptych span { animation: none; opacity: 1; transform: none; }
    .fake-popup { animation: none !important; }
  }

  /* ---------- Decorative Win9x fake popup (the joke) ---------- */
  #philosophy { position: relative; overflow: hidden; }
  .fake-popup {
    position: absolute;
    top: 5rem;
    right: 3rem;
    width: 340px;
    z-index: 5;
    font-family: 'Tahoma', 'MS Sans Serif', Geneva, sans-serif;
    font-size: 12px;
    color: #000;
    background: #c3c3c3;
    /* Classic chiseled bevel */
    border-top: 2px solid #fff;
    border-left: 2px solid #fff;
    border-right: 2px solid #555;
    border-bottom: 2px solid #555;
    box-shadow:
      inset -1px -1px 0 #818181,
      inset 1px 1px 0 #dfdfdf,
      4px 4px 0 rgba(0,0,0,0.18);
    transform: rotate(-1.4deg);
    animation: fp-wobble 0.9s cubic-bezier(.2,.7,.2,1) 0.4s both;
    user-select: none;
  }
  @keyframes fp-wobble {
    0%   { opacity: 0; transform: rotate(-1.4deg) translateY(-30px) scale(0.9); }
    60%  { opacity: 1; transform: rotate(-2.2deg) translateY(4px) scale(1.02); }
    100% { opacity: 1; transform: rotate(-1.4deg) translateY(0) scale(1); }
  }
  .fp-titlebar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(90deg, #000080 0%, #1084d0 100%);
    color: #fff;
    padding: 3px 4px 3px 6px;
    font-weight: 700;
  }
  .fp-title { letter-spacing: 0.02em; }
  .fp-controls { display: flex; gap: 2px; }
  .fp-controls button {
    width: 18px;
    height: 16px;
    padding: 0;
    font-family: inherit;
    font-size: 10px;
    line-height: 1;
    color: #000;
    background: #c3c3c3;
    border-top: 1px solid #fff;
    border-left: 1px solid #fff;
    border-right: 1px solid #555;
    border-bottom: 1px solid #555;
    cursor: default;
  }
  .fp-body {
    display: flex;
    gap: 14px;
    padding: 18px 16px 14px;
    align-items: flex-start;
  }
  .fp-icon {
    flex: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #1084d0;
    color: #fff;
    font-family: 'Times New Roman', serif;
    font-style: italic;
    font-weight: 700;
    font-size: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-top: 2px solid #fff;
    border-left: 2px solid #fff;
    border-right: 2px solid #555;
    border-bottom: 2px solid #555;
  }
  .fp-message p { margin: 0 0 4px; max-width: none; color: #000; line-height: 1.35; }
  .fp-message p:last-child { margin-bottom: 0; }
  .fp-buttons {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 0 16px 14px;
  }
  .fp-btn {
    min-width: 90px;
    padding: 4px 10px;
    font-family: inherit;
    font-size: 12px;
    color: #000;
    background: #c3c3c3;
    border-top: 1px solid #fff;
    border-left: 1px solid #fff;
    border-right: 1px solid #555;
    border-bottom: 1px solid #555;
    box-shadow: inset -1px -1px 0 #818181, inset 1px 1px 0 #dfdfdf;
    cursor: default;
  }
  .fp-btn-primary {
    border-top-color: #555;
    border-left-color: #555;
    border-right-color: #fff;
    border-bottom-color: #fff;
    box-shadow: inset 1px 1px 0 #818181, inset -1px -1px 0 #dfdfdf;
    outline: 1px dotted #000;
    outline-offset: -4px;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .fake-popup { right: 1.4rem; top: 3rem; width: 280px; transform: rotate(-1deg); }
  }
  @media (max-width: 680px) {
    .fake-popup {
      position: relative;
      top: auto;
      right: auto;
      margin: 0 auto 2rem;
      width: 100%;
      max-width: 320px;
      transform: rotate(-1deg);
    }
  }
</style>
