---
// D2 isolated preview route. NOT linked from index.astro — D7 handles integration.
import Layout from "../layouts/Layout.astro";
import Desktop from "../components/desktop/Desktop.astro";
---

<Layout title="Desktop Preview — D2">
  <main style="padding: 24px; max-width: 1280px; margin: 0 auto;">
    <h1 style="font-family: system-ui, sans-serif; margin: 0 0 8px;">Retro Desktop — D2 Preview</h1>
    <p style="font-family: system-ui, sans-serif; color: #555; margin: 0 0 16px;">
      Isolated preview of the React island. Resize ≥1024px with a fine pointer to hydrate.
      Mobile fallback is D4.
    </p>
    <div class="desktop-only">
      <Desktop />
    </div>
    <div class="mobile-only">
      <p style="font-family: system-ui, sans-serif; padding: 24px; border: 1px dashed #aaa;">
        Mobile / coarse-pointer fallback ships in D4.
      </p>
    </div>
  </main>
</Layout>

<style>
  .desktop-only {
    display: none;
  }
  .mobile-only {
    display: block;
  }
  @media (min-width: 1024px) and (pointer: fine) {
    .desktop-only {
      display: block;
    }
    .mobile-only {
      display: none;
    }
  }
</style>
