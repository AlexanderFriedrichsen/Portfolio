---
import Layout from '../layouts/Layout.astro';
import Desktop from '../components/desktop/Desktop.astro';
import MobileFallback from '../components/desktop/MobileFallback.astro';
---

<Layout title="Alex Friedrichsen — Portfolio">
  {/*
    Phase A R5: the retro XP desktop is the ENTIRE site on ≥1024px + fine pointer.
    On smaller/coarse viewports, MobileFallback renders a zero-JS editorial page.
    All legacy editorial movements (triptych/beats/agent-grid/footer) were
    removed in R5 Fix 2 — they were not referenced by either experience and
    were causing a visible flash during the restart fade.
  */}
  <section id="desktop" class="desktop-section">
    <div class="desktop-only">
      <Desktop />
    </div>
    <div class="mobile-only">
      <MobileFallback />
    </div>
  </section>
</Layout>

<style>
  /* Retro desktop section gating: ≥1024px + fine pointer = island, else fallback. */
  .desktop-section .desktop-only { display: none; }
  .desktop-section .mobile-only  { display: block; }
  @media (min-width: 1024px) and (pointer: fine) {
    .desktop-section .desktop-only { display: block; }
    .desktop-section .mobile-only  { display: none; }
    html, body { overflow: hidden; height: 100%; }
  }
</style>

<script>
  // Mark <html> so the global no-scroll rule in desktop.css can latch on.
  if (typeof window !== 'undefined') {
    const mq = window.matchMedia('(min-width: 1024px) and (pointer: fine)');
    const apply = (matches: boolean) => {
      document.documentElement.classList.toggle('has-xp-desktop', matches);
    };
    apply(mq.matches);
    mq.addEventListener('change', (e) => apply(e.matches));
  }
</script>
